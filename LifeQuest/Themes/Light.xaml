<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="ThemeMarker">light</sys:String>

    <Color x:Key="BgColor">#F4F6FB</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#EEF1F8</Color>
    <Color x:Key="BorderColor">#DCE0EA</Color>
    <Color x:Key="TextColor">#1B2333</Color>
    <Color x:Key="MutedColor">#6B7280</Color>
    <Color x:Key="AccentColor">#6D5DF6</Color>
    <Color x:Key="AccentColor2">#8B7BFF</Color>
    <Color x:Key="GoldColor">#D9A400</Color>
    <Color x:Key="GreenColor">#12A150</Color>
    <Color x:Key="WineColor">#B4326B</Color>
    <Color x:Key="DangerColor">#E0435C</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentBrush2" Color="{StaticResource AccentColor2}"/>
    <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="WineBrush" Color="{StaticResource WineColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}"/>

</ResourceDictionary>
