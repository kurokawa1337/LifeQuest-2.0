<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="ThemeMarker">dark</sys:String>

    <Color x:Key="BgColor">#0F1420</Color>
    <Color x:Key="SurfaceColor">#1A2130</Color>
    <Color x:Key="SurfaceAltColor">#232C3D</Color>
    <Color x:Key="BorderColor">#313B50</Color>
    <Color x:Key="TextColor">#EAEEF6</Color>
    <Color x:Key="MutedColor">#9AA4B6</Color>
    <Color x:Key="AccentColor">#8B7BFF</Color>
    <Color x:Key="AccentColor2">#6D5DF6</Color>
    <Color x:Key="GoldColor">#F0C34E</Color>
    <Color x:Key="GreenColor">#3BD07E</Color>
    <Color x:Key="WineColor">#E86AA0</Color>
    <Color x:Key="DangerColor">#FF6B81</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentBrush2" Color="{StaticResource AccentColor2}"/>
    <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="WineBrush" Color="{StaticResource WineColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}"/>

</ResourceDictionary>
