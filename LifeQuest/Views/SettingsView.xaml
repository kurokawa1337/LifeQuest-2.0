<UserControl x:Class="LifeQuest.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock x:Name="TitleText" Style="{StaticResource H1}"/>

            <Border Style="{StaticResource Card}" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock x:Name="AccountLbl" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="56" Height="56">
                            <Ellipse x:Name="AvatarCircle">
                                <Ellipse.Fill><SolidColorBrush Color="{DynamicResource AccentColor}"/></Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="AvatarInitial" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource OnAccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="UsernameText" Style="{StaticResource H2}"/>
                            <TextBlock x:Name="LoggedAsText" Style="{StaticResource Muted}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="ChangeAvatarBtn" Click="ChangeAvatar_Click" Style="{StaticResource BtnGhost}"
                            HorizontalAlignment="Left" Margin="0,14,0,0"/>
                    <TextBlock x:Name="AvatarHint" Style="{StaticResource Muted}" Margin="2,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock x:Name="LangLbl" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="LangUk" Tag="uk" GroupName="lang" Checked="Lang_Checked"
                                     Style="{StaticResource ChipItem}"/>
                        <RadioButton x:Name="LangEn" Tag="en" GroupName="lang" Checked="Lang_Checked"
                                     Style="{StaticResource ChipItem}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock x:Name="ThemeLbl" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ThemeLight" Tag="light" GroupName="theme" Checked="Theme_Checked"
                                     Style="{StaticResource ChipItem}"/>
                        <RadioButton x:Name="ThemeDark" Tag="dark" GroupName="theme" Checked="Theme_Checked"
                                     Style="{StaticResource ChipItem}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,16,0,24">
                <StackPanel>
                    <TextBlock x:Name="DbLbl" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ConnLbl" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                    <TextBox x:Name="ConnBox" Style="{StaticResource Field}" TextWrapping="Wrap" Height="60"
                             AcceptsReturn="True" VerticalContentAlignment="Top" IsReadOnly="True"/>
                    <Button x:Name="TestConnBtn" Click="TestConn_Click" Style="{StaticResource BtnGhost}"
                            HorizontalAlignment="Left" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
